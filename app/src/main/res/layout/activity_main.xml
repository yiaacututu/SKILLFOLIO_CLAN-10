<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Form input dengan 2 Tab:
    • Tab "Pengalaman" → jabatan, organisasi, tahun, deskripsi
    • Tab "Project"    → nama project, teknologi, link, deskripsi project
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111318">

    <!-- ══════════════════════════════════
         TOP BAR
    ══════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A1E2A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SkillFolio"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Data Baru"
                android:textColor="#6B7289"
                android:textSize="11sp" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLihatSemua"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_dark"
            android:text="Lihat Semua"
            android:textColor="#E8E9EC"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2E3D" />

    <!-- ══════════════════════════════════
         TABS: Pengalaman | Project
    ══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#1A1E2A"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabPengalaman"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pengalaman"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/tab_selected_indicator" />

        <TextView
            android:id="@+id/tabProject"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Project"
            android:textColor="#6B7289"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════
         KONTEN SCROLL
    ══════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ════════════════════════════
                 FORM PENGALAMAN (Tab 1)
            ════════════════════════════ -->
            <LinearLayout
                android:id="@+id/formPengalaman"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA PENGALAMAN"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="14dp">

                    <!-- Jabatan / Posisi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="💼"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jabatan / Posisi"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etJabatan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: Ketua Divisi Acara"
                                android:textColorHint="#4A5568"
                                android:inputType="textCapWords"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Organisasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="🏛️"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nama Organisasi / Kepanitiaan"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etOrganisasi"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: BEM Fakultas Teknik"
                                android:textColorHint="#4A5568"
                                android:inputType="textCapWords"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Tahun -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="📅"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tahun Kegiatan"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etTahun"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: 2024"
                                android:textColorHint="#4A5568"
                                android:inputType="number"
                                android:maxLength="4"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Deskripsi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="📝"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deskripsi Kegiatan"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etDeskripsi"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:background="@drawable/bg_edittext_dark"
                                android:gravity="top"
                                android:hint="Jelaskan peran dan tanggung jawab kamu..."
                                android:textColorHint="#4A5568"
                                android:inputType="textMultiLine"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- Tombol Simpan Pengalaman -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSimpan"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_btn_gold"
                    android:text="Simpan Pengalaman"
                    android:textColor="#111318"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

            <!-- ════════════════════════════
                 FORM PROJECT (Tab 2)
            ════════════════════════════ -->
            <LinearLayout
                android:id="@+id/formProject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA PROJECT"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="14dp">

                    <!-- Nama Project -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="🚀"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nama Project"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etNamaProject"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: Skillfolio App"
                                android:textColorHint="#4A5568"
                                android:inputType="textCapWords"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Teknologi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="⚙️"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Teknologi yang Dipakai"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etTeknologi"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: Kotlin, Firebase, Figma"
                                android:textColorHint="#4A5568"
                                android:inputType="text"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Tahun Project -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="📅"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tahun Project"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etTahunProject"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: 2024"
                                android:textColorHint="#4A5568"
                                android:inputType="number"
                                android:maxLength="4"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Link Project -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="🔗"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Link Project / GitHub"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etLinkProject"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edittext_dark"
                                android:hint="cth: github.com/username/project"
                                android:textColorHint="#4A5568"
                                android:inputType="textUri"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" android:layout_marginBottom="14dp" />

                    <!-- Deskripsi Project -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_icon_dark"
                            android:gravity="center"
                            android:text="📝"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deskripsi Project"
                                android:textColor="#6B7289"
                                android:textSize="11sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/etDeskripsiProject"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:background="@drawable/bg_edittext_dark"
                                android:gravity="top"
                                android:hint="Jelaskan project yang kamu buat..."
                                android:textColorHint="#4A5568"
                                android:inputType="textMultiLine"
                                android:padding="11dp"
                                android:textColor="#E8E9EC"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- Tombol Simpan Project -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSimpanProject"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_btn_gold"
                    android:text="Simpan Project"
                    android:textColor="#111318"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

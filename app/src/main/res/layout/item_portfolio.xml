<?xml version="1.0" encoding="utf-8"?>
<!--
    item_portfolio.xml
    Satu item layout untuk RecyclerView campuran (Kegiatan + Project).

    Strategi visibility:
    ┌──────────────────┬───────────────────┬──────────────────┐
    │ View ID          │ Kegiatan          │ Project          │
    ├──────────────────┼───────────────────┼──────────────────┤
    │ viewAccentBar    │ bar emas (#FFD700)│ bar biru (#4A90D9│
    │ tvItemNama       │ jabatan (judul)   │ namaProject      │
    │ tvItemTahun      │ tahun (emas)      │ tahun (biru)     │
    │ tvItemSub1       │ organisasi (abu)  │ teknologi (emas) │
    │ tvItemLink       │ GONE              │ link GitHub      │
    │ tvItemDeskripsi  │ deskripsi         │ deskripsi        │
    │ tvItemInisial    │ inisial jabatan   │ inisial project  │
    │ tvItemTipeLabel  │ "Pengalaman"      │ "Project"        │
    └──────────────────┴───────────────────┴──────────────────┘
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- ── Garis aksen kiri (warna di-set di adapter berdasarkan tipe) ── -->
    <View
        android:id="@+id/viewAccentBar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#FFD700"
        android:layout_marginEnd="14dp" />

    <!-- ── Blok konten tengah ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Baris 1: Nama / Judul -->
        <TextView
            android:id="@+id/tvItemNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E8E9EC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="3dp" />

        <!-- Baris 2: Tahun (emas untuk pengalaman, biru untuk project) -->
        <TextView
            android:id="@+id/tvItemTahun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginBottom="4dp" />

        <!-- Baris 3: Sub-info pertama
             • Kegiatan → organisasi (abu)
             • Project  → teknologi (emas bold) -->
        <TextView
            android:id="@+id/tvItemSub1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="2dp" />

        <!-- Baris 4: Link GitHub/URL — hanya muncul untuk Project -->
        <TextView
            android:id="@+id/tvItemLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#4A90D9"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <!-- Baris 5: Deskripsi singkat (selalu muncul) -->
        <TextView
            android:id="@+id/tvItemDeskripsi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#6B7289"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- ── Avatar + label tipe (kanan) ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvItemInisial"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111318"
            android:background="@drawable/bg_avatar_gold" />

        <TextView
            android:id="@+id/tvItemTipeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textSize="10sp"
            android:textColor="#9AA1B5"
            android:gravity="center"
            android:maxLines="1" />

    </LinearLayout>

</LinearLayout>

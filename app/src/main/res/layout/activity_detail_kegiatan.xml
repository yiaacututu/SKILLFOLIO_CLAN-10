<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_detail_kegiatan.xml
    Halaman detail untuk 1 item pengalaman/kegiatan.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111318">

    <!-- ══════════════════════════════════
         TOP BAR
    ══════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A1E2A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_dark"
            android:src="@drawable/ic_arrow_back"
            android:tint="#E8E9EC"
            android:contentDescription="Kembali" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Detail Pengalaman"
            android:textColor="#E8E9EC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEksporCV"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_gold"
            android:text="Ekspor CV"
            android:textColor="#111318"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2E3D" />

    <!-- ══════════════════════════════════
         KONTEN SCROLL
    ══════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── HERO CARD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <!-- Avatar Inisial -->
                <TextView
                    android:id="@+id/tvDetailInisial"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_avatar_gold"
                    android:gravity="center"
                    android:text="KD"
                    android:textColor="#111318"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Jabatan -->
                    <TextView
                        android:id="@+id/tvDetailJabatan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ketua Divisi"
                        android:textColor="#E8E9EC"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <!-- Organisasi -->
                    <TextView
                        android:id="@+id/tvDetailOrganisasi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BEM Fakultas Teknik"
                        android:textColor="#9AA1B5"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Badge Tahun -->
                    <TextView
                        android:id="@+id/tvDetailTahun"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_gold"
                        android:text="2024"
                        android:textColor="#111318"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />

                </LinearLayout>
            </LinearLayout>

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETAIL PENGALAMAN"
                android:textColor="#FFD700"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Detail Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="16dp">

                <!-- Jabatan row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_dark"
                        android:gravity="center"
                        android:text="💼"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jabatan / Posisi"
                            android:textColor="#6B7289"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvDetailJabatanRow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8E9EC"
                            android:textSize="14sp" />

                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" />

                <!-- Organisasi row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_dark"
                        android:gravity="center"
                        android:text="🏛️"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Organisasi / Kepanitiaan"
                            android:textColor="#6B7289"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvDetailOrganisasiRow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8E9EC"
                            android:textSize="14sp" />

                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" />

                <!-- Tahun row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_dark"
                        android:gravity="center"
                        android:text="📅"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tahun Kegiatan"
                            android:textColor="#6B7289"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvDetailTahunRow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFD700"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#23273A" />

                <!-- Deskripsi row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="top">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_dark"
                        android:gravity="center"
                        android:text="📝"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deskripsi"
                            android:textColor="#6B7289"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvDetailDeskripsi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8E9EC"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.5" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════
         BOTTOM: Ekspor CV
    ══════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2E3D" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnEksporCVBottom"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_gold"
        android:text="Ekspor CV"
        android:textColor="#111318"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
